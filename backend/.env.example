# === Uygulama ===
APP_NAME=Social Media Distribution
DEBUG=False

# === Admin Giriş ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# === JWT ===
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64

# === Veritabanı ===
DATABASE_URL=postgresql://smd_user:CHANGE_ME@db:5432/smd_db

# === MinIO ===
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET_NAME=social-media-uploads
MINIO_PUBLIC_URL=https://storage.YOURDOMAIN.com

# === Meta (Instagram / Facebook) ===
META_CLIENT_ID=
META_CLIENT_SECRET=
META_ACCESS_TOKEN=

# === LinkedIn ===
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# === X / Twitter (henüz aktif değil) ===
